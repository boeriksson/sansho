{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "sansho",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "sansho"
  },
  "runtimes": [
    {
      "name": "hermes",
      "build": "Container",
      "entrypoint": "main.py",
      "codeLocation": "app/hermes/",
      "runtimeVersion": "PYTHON_3_11",
      "networkMode": "PUBLIC",
      "protocol": "HTTP",
      "envVars": [
        { "name": "BEDROCK_MODEL_ID", "value": "eu.anthropic.claude-haiku-4-5-20251001-v1:0" },
        { "name": "HERMES_HEADLESS", "value": "1" },
        { "name": "AGENTCORE_MODE", "value": "1" },
        { "name": "HERMES_PROVIDER", "value": "anthropic" }
      ]
    }
  ],
  "memories": [],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [],
  "policyEngines": [],
  "configBundles": [],
  "abTests": [],
  "httpGateways": [],
  "datasets": []
}