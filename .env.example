# WhatsApp Cloud API credentials.
# These live in AWS Secrets Manager (secret id: sansho/whatsapp) in production;
# this file documents the shape. After deploy, push them with:
#
#   aws secretsmanager put-secret-value --secret-id sansho/whatsapp \
#     --secret-string "$(jq -n --arg a "$WHATSAPP_ACCESS_TOKEN" \
#        --arg p "$WHATSAPP_PHONE_NUMBER_ID" --arg s "$WHATSAPP_APP_SECRET" \
#        --arg v "$WHATSAPP_VERIFY_TOKEN" \
#        '{accessToken:$a, phoneNumberId:$p, appSecret:$s, verifyToken:$v}')"

# Permanent or temporary access token from the Meta App (WhatsApp > API Setup).
WHATSAPP_ACCESS_TOKEN=

# Phone number ID (not the phone number) from WhatsApp > API Setup.
WHATSAPP_PHONE_NUMBER_ID=

# App Secret from Meta App > Settings > Basic. Used to verify webhook signatures.
WHATSAPP_APP_SECRET=

# Any random string you choose; must match the value entered in the Meta webhook config.
WHATSAPP_VERIFY_TOKEN=

# Bedrock model the agent runs on. Default is Claude Haiku 4.5 (cheapest).
# This is set in agentcore/agentcore.json (runtimes[].envVars), not here.
# Switch later to e.g. us.anthropic.claude-sonnet-4-6 and redeploy the runtime.
# BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
